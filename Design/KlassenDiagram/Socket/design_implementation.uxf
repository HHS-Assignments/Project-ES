--
- fd_: int
- host_: std::string
- port_: int
--
+ SocketConnection()
+ ~SocketConnection()
+ connect(host: const std::string&, port: int): bool
+ sendLine(data: const std::string&): bool
+ readLine(): std::string
+ close(): void
+ getFd(): int
+ getHost(): std::string
+ getPort(): int
+ isConnected(): bool</panel_attributes>
