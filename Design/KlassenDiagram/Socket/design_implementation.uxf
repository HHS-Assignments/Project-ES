  <!-- Legend -->
  <element>
    <id>UMLNote</id>
    <coordinates>
      <x>1220</x>
      <y>640</y>
      <w>280</w>
      <h>200</h>
    </coordinates>
    <panel_attributes>UML Legend
--
*-- : Composition
     (strong ownership)
     
o-- : Aggregation
     (weak ownership)
     
&lt;&lt;. : Interface Realization
     (implements)
     
&lt;&lt;&lt;&lt;- : Dependency
         (uses/exchanges)

Multiplicity:
1    : exactly one
0..1 : zero or one
*    : zero or many
1..* : one or many</panel_attributes>
    <additional_attributes/>
  </element>

</diagram>
