      <x>50</x>
      <y>640</y>
      <w>280</w>
      <h>180</h>
    </coordinates>
    <panel_attributes>service::PiAService
--
- peer_: unique_ptr&lt;SocketConnection&gt;
- dispatcher_: unique_ptr&lt;DeviceDispatcher&gt;
--
+ PiAService()
+ start(port: int): void
+ acceptPeer(): void
+ processIncoming(message: const JsonMessage&): void
+ sendAck(status: const std::string&): void
+ getDispatcher(): DeviceDispatcher*</panel_attributes>
    <additional_attributes/>
  </element>

  <element>
    <id>UMLClass</id>
    <coordinates>
