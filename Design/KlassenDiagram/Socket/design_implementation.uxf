      <y>640</y>
      <w>380</w>
      <h>200</h>
    </coordinates>
    <panel_attributes>service::PiBService
--
- wmosServer_: unique_ptr&lt;HttpServer&gt;
- upstream_: unique_ptr&lt;SocketConnection&gt;
- dispatcher_: unique_ptr&lt;DeviceDispatcher&gt;
- workers_: vector&lt;unique_ptr&lt;ThreadPoolWorker&gt;&gt;
--
+ PiBService()
+ start(wmosPort: int, aHost: const std::string&, aPort: int): void
+ forwardToPiA(message: const JsonMessage&): void
+ readFromPiA(): void
+ handleWmosRequest(request: const std::string&): void
+ getHttpServer(): HttpServer*
+ getDispatcher(): DeviceDispatcher*</panel_attributes>
    <additional_attributes/>
  </element>

