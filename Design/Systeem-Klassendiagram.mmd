---
title: Project-ES — Systeem klassendiagram
description: >
  Volledig systeem: BalieConsole, HeadSluis (Luchtsluis) en Lichtvoorziening
  (STM32, procedureel C — gemodelleerd als modules), Pi A (CAN-gateway),
  Pi B (Wemos-gateway) en de Wemos-controllers Lichtkrant en Relaxstoel.
---
classDiagram
    direction LR

    %% ════════════════════════ STM32-NODES (C-modules) ════════════════════════
    namespace STM32 {
        class BalieConsole {
            <<module>>
            -noodActief : uint8_t
            -relaxStoelStatus : uint8_t
            -co2High : uint8_t
            -tempHigh : uint8_t
            -timeOfDay : uint8_t
            -co2 : uint16_t
            -temp : uint8_t
            -ldr : uint16_t
            -menuState : uint8_t
            -meldingen : char[5][32]
            +HandleCommand(cmd) void
            +SendColor(kleur) void
            +SendBrightness(procent) void
            +AddMelding(msg) void
            +SendCanMessage(len, data, canID) void
            +HAL_UART_RxCpltCallback() void
            +HAL_CAN_RxFifo0MsgPendingCallback() void
            +HAL_GPIO_EXTI_Callback(pin) void
        }

        class LuchtSluis {
            <<module>>
            -state : system_state_t
            -servo1_pos : int
            -servo2_pos : int
            -UIDDatabase : uint8_t[][4]
            -DoorloopCyclus : uint8_t
            +KaiDeurAutomatiseringBuitenBinnen() void
            +KaiDeurAutomatiseringBinnenBuiten() void
            +ResetDeuren() void
            +Servo_Move_Smooth(kanaal, van, naar, stap) void
            +max7219_show_2d(patroon) void
            +SendCanMessage(len, data, canID) void
            +HAL_CAN_RxFifo0MsgPendingCallback() void
            +HAL_GPIO_EXTI_Callback(pin) void
        }

        class system_state_t {
            <<enumeration>>
            STATE_NORMAL
            STATE_EMERGENCY
            STATE_ALLOPEN
        }

        class MFRC522_STM32 {
            <<driver>>
            +MFRC522_Init(rfid) status
            +MFRC522_RequestA(rfid, atqa) status
            +MFRC522_ReadUid(rfid, uid) status
        }

        class Lichtvoorziening {
            <<module>>
            -noodActief : uint8_t
            -huidigeKleur : uint8_t
            -helderheid : uint8_t
            -led_on : uint8_t
            -mc_colors : Color[12]
            +SGP30_Init() void
            +SGP30_ReadCO2() uint16_t
            +SHT3x_Read(temp) void
            +RGB_Set(r, g, b, helderheid) void
            +chase_tick(stap) void
            +SendCanMessage(len, data, canID) void
            +HAL_CAN_RxFifo0MsgPendingCallback() void
            +HAL_GPIO_EXTI_Callback(pin) void
        }

        class WS2812B {
            <<driver>>
            +WS2812B_SetLED(i, r, g, b) void
            +WS2812B_Clear() void
            +WS2812B_DMA_HalfCpltCallback() void
            +WS2812B_DMA_CpltCallback() void
        }
    }

    %% ════════════════════════ PI A — CAN-GATEWAY ════════════════════════
    namespace PiA_CanGateway {
        class Pi_Communication {
            <<interface>>
            +begin() bool
            +send(line) bool
            +receive(line) bool
            +isConnected() bool
            +stop() void
        }

        class BusCommunication {
            <<interface>>
            +readMessage(msg) bool
            +writeMessage(msg) bool
        }

        class CanMessage {
            +id : uint32_t
            +data : uint8_t[8]
            +len : uint8_t
        }

        class CAN {
            -_iface : string
            -_fd : int
            +begin() bool
            +readMessage(msg) bool
            +writeMessage(msg) bool
            +isConnected() bool
            +stop() void
        }

        class PiSocketServer {
            -_port : uint16_t
            -_srvFd : int
            -_peerFd : int
            +begin() bool
            +send(line) bool
            +receive(line) bool
            +isConnected() bool
            +stop() void
        }

        class DataParserA {
            +messageToJson(msg) string
            +jsonToMessage(line, msg) bool
            +isTextId(id)$ bool
            +parseTijdConfig(msg, dagH, dagM, nachtH, nachtM)$ bool
        }

        class Vergelijking {
            <<enumeration>>
            Groter
            Kleiner
            Gelijk
            Altijd
        }

        class Automation {
            +name : string
            +hour : int
            +minute : int
            +triggerId : uint32_t
            +vergelijking : Vergelijking
            +drempel : int
            +conditieWasWaar : bool
            +actieId : uint32_t
            +actieData : uint8_t
        }

        class AutomationEngine {
            -_regels : vector~Automation~
            -_edgeTriggered : bool
            +addTijdActie(uur, min, actieId, data, naam) void
            +addCanActie(triggerId, vgl, drempel, actieId, data, naam) void
            +setEdgeTriggered(edge) void
            +onCanMessage(msg) void
            +setDagNachtTijden(dagH, dagM, nachtH, nachtM) void
            +evalueerNu() void
            +start(fire) void
            +stop() void
        }

        class CanGatewayController {
            <<singleton>>
            +getInstance()$ CanGatewayController
            +init(bus, socket, parser, automation) void
            +begin() bool
            +run() void
            +stop() void
            -_busNaarSocket() void
            -_socketNaarBus() void
        }
    }

    %% ════════════════════════ PI B — WEMOS-GATEWAY ════════════════════════
    namespace PiB_WemosGateway {
        class PiSocketClient {
            -_host : string
            -_port : uint16_t
            -_fd : int
            +begin() bool
            +send(line) bool
            +receive(line) bool
            +isConnected() bool
            +stop() void
        }

        class WemosTarget {
            +name : string
            +ip : string
            +port : uint16_t
        }

        class WemosCommunication {
            -_receivePort : uint16_t
            -_targets : vector~WemosTarget~
            +begin() bool
            +send(line) bool
            +receive(line) bool
            +isConnected() bool
            +stop() void
        }

        class DataParserB {
            +isValid(line) bool
        }

        class WemosGatewayController {
            <<singleton>>
            +getInstance()$ WemosGatewayController
            +init(piSocket, wemos, parser) void
            +begin() bool
            +run() void
            +stop() void
            -_piNaarWemos() void
            -_wemosNaarPi() void
        }
    }

    %% ════════════════════════ WEMOS — GEDEELDE COMMUNICATIE ════════════════════════
    namespace Wemos_Gedeeld {
        class Wemos_Communication {
            <<interface>>
            +begin() void
            +send(data) bool
            +receive(buf, len) bool
            +sendCanJson(canId, data) bool
            +isConnected() bool
            +connect(ssid, pass) bool
            +reconnect() void
        }

        class WirelessCommunication {
            <<interface>>
            +connect(ssid, pass) bool
            +isConnected() bool
        }

        class WiFiCommunication {
            -_piHost : string
            -_piPort : int
            -_server : WiFiServer
            +begin() void
            +connect(ssid, pass) bool
            +reconnect() void
            +isConnected() bool
            +send(data) bool
            +receive(buf, len) bool
            +sendCanJson(canId, data) bool
        }
    }

    %% ════════════════════════ WEMOS LICHTKRANT ════════════════════════
