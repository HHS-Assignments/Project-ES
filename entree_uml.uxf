--
-id: String
-locatie: String
-bewegingGedetecteerd: bool
--
+detecteer(): bool
+triggerActie(): void</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- Lichtkrant -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>300</x><y>540</y><w>180</w><h>100</h></coordinates>
    <panel_attributes>Lichtkrant
--
-huidigeBericht: String
-scrollSnelheid: int
--
+toonBericht(tekst: String): void
+setBericht(tekst: String): void
