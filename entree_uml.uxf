<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<diagram program="umlet" version="15.1">
  <zoom_level>8</zoom_level>

  <!-- Entree -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>440</x><y>20</y><w>160</w><h>80</h></coordinates>
    <panel_attributes>Entree
--
--
+beheer()
+monitorStatus()</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- Luchtsluis -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>60</x><y>180</y><w>200</w><h>120</h></coordinates>
    <panel_attributes>Luchtsluis
--
-binnendeur: Deur
-buitendeur: Deur
-buitenTemp: float
-binnenTemp: float
--
+verwerkToegang(kaart: RFIDKaart): bool
+meetTemperatuur(): void
+noodprocedure(): void</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- CentraleHal -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>440</x><y>180</y><w>200</w><h>100</h></coordinates>
    <panel_attributes>CentraleHal
--
-bezetting: int
--
+updateVerlichting(): void
+detecteerBeweging(): void
+toonInformatie(tekst: String): void</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- Balie -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>820</x><y>180</y><w>200</w><h>100</h></coordinates>
    <panel_attributes>Balie
--
-medewerker: String
--
+pasInstellingAan(instelling: String, waarde: String): void
+getStatusLEDs(): LEDStatus
+controleerVerdieping(): void</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- RFIDLezer -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>20</x><y>400</y><w>160</w><h>80</h></coordinates>
    <panel_attributes>RFIDLezer
--
-id: String
--
+leesKaart(): RFIDKaart
+validerenKaart(kaart: RFIDKaart): bool</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- RFIDKaart -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>20</x><y>540</y><w>160</w><h>80</h></coordinates>
    <panel_attributes>RFIDKaart
--
-kaartID: String
-gebruiker: String
--
+getID(): String</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- Deur -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>200</x><y>400</y><w>160</w><h>80</h></coordinates>
    <panel_attributes>Deur
--
-isOpen: bool
-positie: String
--
+open(): void
+sluit(): void
+getStatus(): bool</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- NoodKnop -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>20</x><y>680</y><w>160</w><h>80</h></coordinates>
    <panel_attributes>NoodKnop
--
-locatie: String
-ingedrukt: bool
--
+druk(): void
+triggerAlarm(): void</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- TemperatuurSensor -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>200</x><y>540</y><w>180</w><h>80</h></coordinates>
    <panel_attributes>TemperatuurSensor
--
-locatie: String
-huidigeWaarde: float
--
+meetTemperatuur(): float
+getLocatie(): String</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- RGBLamp -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>300</x><y>400</y><w>180</w><h>100</h></coordinates>
    <panel_attributes>RGBLamp
--
-rood: int
-groen: int
-blauw: int
-aanUit: bool
--
+setKleur(r: int, g: int, b: int): void
+aan(): void
+uit(): void
+dimmen(niveau: int): void</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- BewegingsDetector -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>500</x><y>400</y><w>180</w><h>80</h></coordinates>
